# MinIO environment configuration template
# Generated by BCM from cluster.conf
# Variables: __MINIO_VOLUMES__, __MINIO_SITE_NAME__, __MINIO_SITE_REGION__
#            __MINIO_ROOT_USER__, __MINIO_ROOT_PASSWORD__, __MINIO_DOMAIN__

# ──── MinIO Server Settings ──────────────────────────────────────────────────

# Data directory (local storage path)
MINIO_VOLUMES="__MINIO_VOLUMES__"

# MinIO root credentials
MINIO_ROOT_USER="__MINIO_ROOT_USER__"
MINIO_ROOT_PASSWORD="__MINIO_ROOT_PASSWORD__"

# Site identification (unique per node for Site Replication)
MINIO_SITE_NAME="__MINIO_SITE_NAME__"
MINIO_SITE_REGION="__MINIO_SITE_REGION__"

# Server address
MINIO_ADDRESS=":9000"
MINIO_CONSOLE_ADDRESS=":9001"

# ──── Virtual-host bucket addressing (ОБЯЗАТЕЛЬНО для модуля Bitrix «Облачные
# хранилища») ───────────────────────────────────────────────────────────────
# Модуль clouds (CCloudStorageService_S3) умеет ТОЛЬКО virtual-hosted-style
# (запрос идёт на bucket.<домен>), path-style он не поддерживает. MINIO_DOMAIN
# заставляет MinIO вынимать бакет из Host-заголовка (bitrix-upload.<домен>).
# Аддитивно: path-style по IP (mc, бэкапы, site-replication по IP) продолжает
# работать. На web-нодах <домен> и bucket.<домен> резолвятся в /etc/hosts на S3-VIP.
MINIO_DOMAIN="__MINIO_DOMAIN__"

# Logging
MINIO_LOGGER_HTTP_ENDPOINT=""

# ──── Site Replication (Active-Active) ──────────────────────────────────────
# Site Replication настраивается командой:
#   mc admin replicate add site1 site2
# после запуска обоих инстансов MinIO
# BCM выполняет эту команду автоматически при первичной настройке

# ──── TLS (опционально) ─────────────────────────────────────────────────────
# MINIO_CERT_FILE="/etc/minio/tls/public.crt"
# MINIO_KEY_FILE="/etc/minio/tls/private.key"
