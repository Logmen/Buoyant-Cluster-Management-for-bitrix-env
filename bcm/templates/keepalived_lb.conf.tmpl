# Keepalived configuration for LB nodes
# Generated by BCM from cluster.conf
# Template variables: __NODE_IFACE__, __NODE_IP__, __VIP__, __PRIORITY__, __PEER_IP__

global_defs {
    router_id __NODE_NAME__
    script_user root
    enable_script_security
}

# Health check: HAProxy process running
vrrp_script chk_haproxy {
    script "pgrep haproxy"
    interval 2
    weight 20
    fall 2
    rise 2
}

vrrp_instance VI_1 {
    state __VRRP_STATE__
    interface __NODE_IFACE__
    virtual_router_id 51
    priority __PRIORITY__
    advert_int 1
    preempt_delay 10

    authentication {
        auth_type PASS
        auth_pass __VRRP_AUTH_PASS__
    }

    virtual_ipaddress {
        __VIP__/32
    }

    track_script {
        chk_haproxy
    }

    unicast_src_ip __NODE_IP__
    unicast_peer {
        __PEER_IP__
    }

    notify_master "/opt/bcm/bin/lib/keepalived_notify.sh MASTER __NODE_NAME__"
    notify_backup "/opt/bcm/bin/lib/keepalived_notify.sh BACKUP __NODE_NAME__"
    notify_fault  "/opt/bcm/bin/lib/keepalived_notify.sh FAULT  __NODE_NAME__"
}
