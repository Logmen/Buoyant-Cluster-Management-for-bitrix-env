-- lsyncd configuration template
-- Generated by BCM from cluster.conf
-- Variables: SOURCE_WEB_IP (web01 IP), TARGET_WEB_IP (web02 IP), SITE_ROOT
-- Manages real-time file sync between web nodes
--
-- ⚠ ЭТОТ ШАБЛОН НЕ РЕНДЕРИТСЯ (рудимент). Боевой конфиг lsyncd генерирует
-- bcm/bin/lib/lsyncd_role.sh::_gen_lsyncd_conf (источник следует за master
-- web-VRRP), начальную сверку — menu/06_lsyncd.sh. Предохранители (--max-delete,
-- exclude /bitrix/updates, sanity-гейт, заморозка в single-режиме) живут ТАМ.

settings {
    logfile    = "/var/log/lsyncd/lsyncd.log",
    statusFile = "/var/run/lsyncd/lsyncd.status",
    statusInterval = 30,
    -- Используем inotify для мгновенной реакции на изменения
    inotifyMode = "CloseWrite",
    maxProcesses = 4,
    -- Задержка синхронизации (секунды) — даёт время на batch-изменения
    delay = 2,
}

-- ──── Синхронизация файлов сайта web01 → web02 ──────────────────────────────
-- ВАЖНО: sync запускается только после деплоя портала на web01
-- Каждый сайт добавляется отдельным блоком sync
-- SYNC_BLOCKS — заполняется BCM генератором

__SYNC_BLOCKS__

