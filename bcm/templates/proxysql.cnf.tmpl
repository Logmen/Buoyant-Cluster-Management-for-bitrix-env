# ProxySQL configuration template
# Generated by BCM from cluster.conf
# Variables substituted by BCM generator:
#   __ADMIN_USER__, __ADMIN_PASSWORD__, __PROXY_PORT__, __ADMIN_PORT__
#   __HG_WRITE__ (10), __HG_READ__ (20)
#   __MONITOR_USER__, __MONITOR_PASS__
#   MYSQL_SERVERS_LIST — список серверов

datadir="/var/lib/proxysql"
errorlog="/var/log/proxysql/proxysql.log"

admin_variables=
{
    admin_credentials="__ADMIN_USER__:__ADMIN_PASSWORD__;radmin:__RADMIN_PASSWORD__"
    # Админский интерфейс слушает только localhost — BCM обращается к нему
    # через mysql -h127.0.0.1. Так порт 6032 не выставлен в сеть кластера.
    mysql_ifaces="127.0.0.1:__ADMIN_PORT__"
    refresh_interval=2000
    # Web-консоль ProxySQL выключена (иначе открытый порт 6080 без TLS).
    web_enabled=false
    web_port=6080
    stats_credentials="stats:stats"
}

mysql_variables=
{
    threads=4
    max_connections=2048
    default_query_delay=0
    default_query_timeout=36000000
    have_compress=true
    poll_timeout=2000
    # 6033 — боевой порт Bitrix (.settings.php host=127.0.0.1:6033).
    # ⚠️ 127.0.0.1:3306 — для management-проверок bitrix-env (bx-sites/site_status):
    # его bx_test_mysql_opts ХАРДКОДИТ port=3306 на 127.0.0.1; локального mysqld у нас
    # нет (БД на PXC) → без этого интерфейса сайт висит в статусе error и bitrix-env
    # не видит модули (transformer и пр.). ProxySQL отвечает на 3306 → проверка проходит.
    interfaces="0.0.0.0:__PROXY_PORT__;127.0.0.1:3306"
    default_schema="information_schema"
    stacksize=1048576
    server_version="8.0.45"
    # Bitrix ходит через ProxySQL → именно эти дефолты он видит в сессии.
    # Пустой sql_mode и время БД == время web — требования «проверки системы» Bitrix.
    default_sql_mode=""
    default_time_zone="__DB_TIMEZONE__"
    connect_timeout_server=3000
    monitor_username="__MONITOR_USER__"
    monitor_password="__MONITOR_PASS__"
    monitor_history=600000
    monitor_connect_interval=60000
    monitor_ping_interval=10000
    monitor_read_only_interval=1500
    monitor_read_only_timeout=500
    ping_interval_server_msec=120000
    ping_timeout_server=500
    commands_stats=true
    sessions_sort=true
    connect_retries_on_failure=10
}

# MySQL servers — заполняется BCM генератором
# Формат: { address="IP", port=3306, hostgroup=HG_ID, max_connections=200, weight=1 }
mysql_servers=
(
__MYSQL_SERVERS__
)

# Query rules: маршрутизация write/read
mysql_query_rules=
(
    {
        # Правило 1: BEGIN/START TRANSACTION → HG_WRITE
        rule_id=1
        active=1
        match_pattern="^(BEGIN|START TRANSACTION|COMMIT|ROLLBACK)"
        destination_hostgroup=__HG_WRITE__
        apply=1
    },
    {
        # Правило 2: SELECT FOR UPDATE → HG_WRITE (exclusive lock)
        rule_id=2
        active=1
        match_pattern="SELECT.*FOR UPDATE"
        destination_hostgroup=__HG_WRITE__
        apply=1
    },
    {
        # Правило 3: именованные блокировки → HG_WRITE.
        # Bitrix активно использует GET_LOCK/RELEASE_LOCK. Они node-local, поэтому
        # блокировка и защищаемые ею записи ДОЛЖНЫ идти на одну ноду (writer),
        # иначе блокировка бесполезна. Должно стоять ДО правила ^SELECT.
        rule_id=3
        active=1
        match_pattern="(GET_LOCK|RELEASE_LOCK|IS_FREE_LOCK|IS_USED_LOCK|RELEASE_ALL_LOCKS)"
        destination_hostgroup=__HG_WRITE__
        apply=1
    },
    {
        # Правило 4: остальные SELECT → HG_READ
        # ВНИМАНИЕ: режим единой ноды (bcm_cluster_mode.sh) переключает именно
        # rule_id=4 на HG_WRITE. При изменении нумерации правил — поправить там.
        rule_id=4
        active=1
        match_pattern="^SELECT"
        destination_hostgroup=__HG_READ__
        apply=1
    }
    # Правило по умолчанию (все остальное) → HG_WRITE (настраивается через mysql_users)
)

mysql_users=
(
    {
        username="__BITRIX_DB_USER__"
        password="__BITRIX_DB_PASS__"
        default_hostgroup=__HG_WRITE__
        transaction_persistent=1
        active=1
    }
)

mysql_galera_hostgroups=
(
    {
        writer_hostgroup=__HG_WRITE__
        backup_writer_hostgroup=__HG_BACKUP_WRITE__
        reader_hostgroup=__HG_READ__
        offline_hostgroup=__HG_OFFLINE__
        active=1
        max_writers=1
        # PXC multi-master: все ноды read_only=0, поэтому без этого reader_hostgroup
        # остаётся пустым (не-writer ноды уходят в backup_writer) и чтения виснут.
        # 2 = backup-writers также обслуживают чтения (HG_READ), failover writer'а сохраняется.
        writer_is_also_reader=2
        max_transactions_behind=100
    }
)
