# Keepalived configuration for WEB nodes (HA Cron)
# Generated by BCM from cluster.conf
# VRID = keepalived_vrid from [layer.web] section
# This is separate from LB VIP — used to ensure Bitrix agents run on ONE web node only

global_defs {
    router_id __NODE_NAME___cron
    script_user root
    enable_script_security
}

# Health check: nginx is running
vrrp_script chk_nginx {
    script "pgrep nginx"
    interval 2
    weight 10
    fall 2
    rise 2
}

# VRID __VRID__ — for HA Cron (Bitrix agents)
vrrp_instance VI___VRID__ {
    state __VRRP_STATE__
    interface __NODE_IFACE__
    virtual_router_id __VRID__
    priority __PRIORITY__
    advert_int 1

    authentication {
        auth_type PASS
        auth_pass __VRRP_CRON_PASS__
    }

    # No virtual IP needed — we just use MASTER/BACKUP state tracking
    # Bitrix cron reads state from keepalived
    virtual_ipaddress {
        # Используем link-local IP как anchor для определения MASTER
        # не добавляется на внешний интерфейс
        127.0.0.254/32 dev lo
    }

    track_script {
        chk_nginx
    }

    unicast_src_ip __NODE_IP__
    unicast_peer {
        __PEER_IP__
    }

    notify_master "/opt/bcm/bin/lib/cron_notify.sh MASTER"
    notify_backup "/opt/bcm/bin/lib/cron_notify.sh BACKUP"
}
