# Percona XtraDB Cluster (PXC) / Galera configuration template
# Generated by BCM from cluster.conf
# Variables: __SERVER_ID__, __NODE_NAME__, __NODE_IP__,
#            __CLUSTER_NAME__, __GALERA_NODES_LIST__, __SST_USER__, __SST_PASS__

[mysqld]

# ──── Basic Settings ─────────────────────────────────────────────────────────
server-id                   = __SERVER_ID__
datadir                     = /var/lib/mysql
socket                      = /var/run/mysqld/mysqld.sock
pid-file                    = /var/run/mysqld/mysqld.pid
log-error                   = /var/log/mysql/error.log
bind-address                = 0.0.0.0
max_connections             = 500
max_allowed_packet          = 256M
character-set-server        = utf8mb4
collation-server            = utf8mb4_unicode_ci
# Время БД ДОЛЖНО совпадать с web-сервером (Bitrix проверяет на «проверке системы»).
# BCM подставляет смещение web-нод (напр. '+05:00'); по умолчанию '+00:00'.
default_time_zone           = '__DB_TIMEZONE__'

# ──── Bitrix-совместимость (проверка системы) ────────────────────────────────
# Bitrix требует ПУСТОЙ sql_mode и innodb_strict_mode=OFF. Иначе «проверка системы»
# ругается, а часть DDL модулей (старые ROW_FORMAT/KEY_BLOCK_SIZE) падает под
# strict-режимом. Совместимо с Galera (PK по-прежнему контролирует pxc_strict_mode).
sql_mode                    = ""
innodb_strict_mode          = OFF

# ──── InnoDB Settings ────────────────────────────────────────────────────────
innodb_buffer_pool_size     = __INNODB_BUFFER_SIZE__
innodb_log_file_size        = 256M
# Bitrix-тест производительности рекомендует =2 (было 0). Для Galera безопасно:
# даже при потере локального redo (flush раз/сек) данные есть на других нодах
# (синхронная репликация), а =2 пишет в OS-кэш на каждый commit — компромисс.
innodb_flush_log_at_trx_commit = 2
innodb_flush_method         = O_DIRECT
innodb_file_per_table       = ON
innodb_autoinc_lock_mode    = 2   # ВАЖНО: обязательно для Galera multi-master
# Bitrix требует READ-COMMITTED (тест показывал REPEATABLE-READ). Galera
# поддерживает READ-COMMITTED и REPEATABLE-READ — переключение безопасно.
transaction-isolation       = READ-COMMITTED

# ──── Авторизация ────────────────────────────────────────────────────────────
# ⚠️ MySQL/PXC 8.4: плагин mysql_native_password ПО УМОЛЧАНИЮ ВЫКЛЮЧЕН.
# Пользователи bitrix/monitor создаются IDENTIFIED WITH mysql_native_password
# (бэкенд ProxySQL не работает с caching_sha2) — без этой опции они не смогут
# аутентифицироваться и весь ProxySQL-роутинг ляжет.
mysql_native_password       = ON

# ──── Binary Logging ─────────────────────────────────────────────────────────
log_bin                     = /var/log/mysql/mysql-bin
binlog_format               = ROW   # ОБЯЗАТЕЛЬНО для Galera
# ⚠️ 8.4: expire_logs_days УДАЛЕНА (mysqld с ней НЕ СТАРТУЕТ) — только секунды.
binlog_expire_logs_seconds  = 432000   # 5 дней
max_binlog_size             = 100M
# Bitrix-тест: sync_binlog=0 (было 1) — не fsync-ить binlog на каждый commit;
# в кластере его долговечность некритична (репликация идёт через wsrep, не binlog).
sync_binlog                 = 0
# Bitrix-тест: Binlog_cache_disk_use>0 при 32K → поднимаем кэш транзакционного binlog.
binlog_cache_size           = 2M

# ──── Galera / WSREP Settings ────────────────────────────────────────────────
wsrep_on                    = ON
wsrep_provider              = /usr/lib64/galera4/libgalera_smm.so

# Cluster name — берётся из cluster.conf
wsrep_cluster_name          = "__CLUSTER_NAME__"

# Список всех узлов кластера (gcomm URI)
# Заполняется BCM: gcomm://ip1,ip2,ip3
wsrep_cluster_address       = "gcomm://__GALERA_NODES_LIST__"

# Идентификация этого узла
wsrep_node_name             = "__NODE_NAME__"
wsrep_node_address          = "__NODE_IP__"

# SST метод (State Snapshot Transfer) — используем xtrabackup-v2
wsrep_sst_method            = xtrabackup-v2

# Performance tuning for Galera
wsrep_applier_threads       = 4
wsrep_sync_wait             = 0
wsrep_retry_autocommit      = 3
wsrep_max_ws_rows           = 131072
wsrep_max_ws_size           = 1073741824

# PXC strict mode: для Bitrix ОБЯЗАТЕЛЬНО PERMISSIVE, а не ENFORCING.
# Bitrix использует GET_LOCK() (именованные блокировки) и LOCK TABLES (дамп/импорт),
# которые ENFORCING запрещает (ошибки 1105). PERMISSIVE их разрешает (с предупреждением
# в логе). Блокировки направляются на единственный writer через ProxySQL (см.
# proxysql.cnf.tmpl: GET_LOCK → HG_WRITE), поэтому остаются консистентными.
pxc_strict_mode             = PERMISSIVE

# ──── ProxySQL monioring user access ─────────────────────────────────────────
# (пользователь создаётся BCM автоматически при настройке ProxySQL)

# ──── Logging для мониторинга ─────────────────────────────────────────────────
slow_query_log              = ON
slow_query_log_file         = /var/log/mysql/slow.log
long_query_time             = 3

[mysql]
socket                      = /var/run/mysqld/mysqld.sock

[client]
socket                      = /var/run/mysqld/mysqld.sock
