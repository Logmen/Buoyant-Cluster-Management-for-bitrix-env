# HAProxy configuration template for Buoyant Cluster Management for bitrix-env
# Generated by bcm from /etc/bitrix-cluster/cluster.conf
# Variables substituted: BCM_VIP, BCM_WEB_NODES_BACKENDS, BCM_S3_NODES_BACKENDS
# DO NOT EDIT MANUALLY — регенерируется повторным запуском install.sh (идемпотентно)

global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    pidfile /var/run/haproxy.pid
    maxconn 50000
    user haproxy
    group haproxy
    daemon
    stats socket /run/haproxy-admin.sock mode 660 level admin expose-fd listeners
    stats timeout 30s

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    option  http-server-close
    timeout connect 5s
    timeout client  50s
    timeout server  50s
    # WebSocket (push-server wss через :443) и long-poll: после апгрейда соединение
    # живёт под timeout tunnel, иначе ws-коннекты рвались бы каждые 50s (timeout server).
    timeout tunnel  1h
    # errorfile 400 /etc/haproxy/errors/400.http
    # errorfile 403 /etc/haproxy/errors/403.http
    # errorfile 408 /etc/haproxy/errors/408.http
    # errorfile 500 /etc/haproxy/errors/500.http
    # errorfile 502 /etc/haproxy/errors/502.http
    # errorfile 503 /etc/haproxy/errors/503.http
    # errorfile 504 /etc/haproxy/errors/504.http

# ──── Статистика HAProxy ─────────────────────────────────────────────────────
listen stats
    bind *:8404
    stats enable
    stats uri /stats
    stats refresh 10s
    stats auth bcm:__BCM_STATS_PASSWORD__
    # admin (enable/disable backend через HTTP) — только с localhost. BCM управляет
    # бэкендами через admin-сокет /run/haproxy-admin.sock, удалённый HTTP-admin не нужен;
    # `if TRUE` открывало бы управление любому, кто знает stats-пароль на :8404.
    stats admin if LOCALHOST

# ──── Frontend: HTTP :80 → web-ноды ─────────────────────────────────────────
frontend http_frontend
    bind *:80
    bind *:443 ssl crt /etc/haproxy/certs/ alpn h2,http/1.1
    option forwardfor
    # X-Forwarded-Proto выставляем ВСЕГДА (https при TLS, иначе явно http) — клиент
    # не может подсунуть поддельный заголовок, а Apache на web-нодах превращает его
    # в HTTPS=on (SetEnvIf в httpd.conf bitrix-env) и nginx — в порт Host (map).
    http-request set-header X-Forwarded-Proto https if { ssl_fc }
    http-request set-header X-Forwarded-Proto http unless { ssl_fc }
    http-request set-header X-Forwarded-Port %[dst_port]

    # ACME HTTP-01 (Let's Encrypt): challenge приходит на VIP:80 → отдать ответчику
    # acme.sh --standalone, поднятому на время выпуска на одном из LB (см. ssl_certs.sh).
    acl is_acme path_beg /.well-known/acme-challenge/
    use_backend acme_backend if is_acme

    # ⚠️ CSS/JS-оптимизация Bitrix (/bitrix/cache/css|js): объединённые файлы с
    # контент-хэшем в имени генерятся ЛЕНИВО и ПОНОДОВО (каталог исключён из lsyncd)
    # → файл существует только на ноде, отрендерившей страницу. При round-robin
    # запрос ассета может попасть на ДРУГУЮ ноду → 404 (рвёт kanban/CRM: «Cannot read
    # properties of undefined»). Отдельный backend с retry-on 404: при 404 HAProxy
    # переотправляет идемпотентный GET на другую ноду (redispatch), где файл есть.
    # Active-active сохраняется (без sticky/двусторонней синхронизации кэша).
    acl is_bx_cache path_beg /bitrix/cache/css/ /bitrix/cache/js/
    use_backend web_cache_backend if is_bx_cache

    # Принудительный HTTPS — управляется BCM (меню «SSL-сертификаты»), не править
    # вручную: маркер bcm:force_https используется для включения/выключения sed'ом.
    # ACME-challenge исключён — выпуск LE должен работать и при включённом редиректе.
    # http-request redirect scheme https if !{ ssl_fc } !is_acme # bcm:force_https

    # Админка/запись (обновление модулей, маркетплейс, файловый редактор) — всегда
    # на источник lsyncd, иначе изменения на не-источнике затрутся синхронизацией.
    acl is_bitrix_admin path_beg /bitrix/admin
    use_backend web_admin_backend if is_bitrix_admin

    default_backend web_backend

# ──── Backend: web-ноды (roundrobin + sticky) — публичный трафик ─────────────
# ⚠️ cookie-аффинность ОБЯЗАТЕЛЬНА: многошаговый загрузчик Bitrix (BX:Main:Uploader,
# Диск/CRM) держит состояние догрузки node-local → без sticky round-robin рвёт
# finalize/resume («Could not resume file transfer», дубли-сироты в S3, нет Disk-
# объекта). insert+indirect+nocache: HAProxy сам ставит свою cookie (BXSRV), серверу
# её не шлёт, добавляет Cache-control. HA цел: при падении ноды cookie протухает →
# redispatch на живую (сессия в общем redis). Ассеты/админка — отдельные backend'ы.
backend web_backend
    balance roundrobin
    cookie BXSRV insert indirect nocache
    option httpchk GET /
    http-check expect status 200
    # Строки для каждой web-ноды добавляются генератором (с `cookie <name>`):
    # server __NODE_NAME__ __NODE_IP__:80 cookie __NODE_NAME__ check inter 2s fall 3 rise 2
__BCM_WEB_NODES_BACKENDS__

# ──── Backend: CSS/JS-кэш Bitrix — retry-on 404 на другую ноду ────────────────
# Ассеты /bitrix/cache/css|js генерятся поноводно (контент-хэш в имени) и НЕ
# синкаются lsyncd. retries + option redispatch 1 + retry-on 404: если выбранная
# нода отдала 404, GET автоматически переотправляется на ДРУГУЮ ноду, где файл есть
# (redispatch 1 — перекидывать на каждом ретрае, не дожидаясь последнего). Те же
# серверы/health-check, что и web_backend.
backend web_cache_backend
    balance roundrobin
    retries 2
    option redispatch 1
    retry-on 404
    option httpchk GET /
    http-check expect status 200
__BCM_WEB_CACHE_BACKENDS__

# ──── Backend: админка/запись — только источник lsyncd (остальные backup) ────
backend web_admin_backend
    balance first
    option httpchk GET /
    # Источник lsyncd идёт первым (primary), остальные — с ключом backup.
    # Генератор добавляет строки server ... [backup]:
__BCM_WEB_ADMIN_BACKENDS__

# ──── Backend: ACME HTTP-01 (Let's Encrypt) ──────────────────────────────────
# Ответчик (acme.sh --standalone) живёт секунды и только на том LB, где идёт
# выпуск, — поэтому БЕЗ health-check: redispatch перекидывает коннект на живой
# сервер. Не зависит от того, какой LB сейчас VRRP-master.
backend acme_backend
    balance roundrobin
    option redispatch
    retries 3
    # Строки для каждой lb-ноды добавляются генератором:
    # server __NODE_NAME__ __NODE_IP__:__ACME_PORT__
__BCM_ACME_BACKENDS__

# ──── Frontend: S3 MinIO :9000 ───────────────────────────────────────────────
frontend s3_frontend
    bind *:9000
    mode tcp
    option tcplog
    default_backend s3_backend

# ──── Backend: S3 MinIO-ноды (active-backup) ────────────────────────────────
# ⚠️ active-backup, НЕ round-robin: сайты MinIO НЕЗАВИСИМЫ (site replication, не
# distributed). S3 multipart создаёт uploadId на одном сайте → round-robin раскидал бы
# part/complete по сайтам → uploadId не найден → загрузка в Диск/CRM рвётся
# («Could not resume file transfer»). Весь трафик → первый сайт; остальные — backup
# (горячий резерв, синхронен через site replication; подхват при падении первого).
backend s3_backend
    mode tcp
    balance roundrobin
    option tcp-check
    # Строки для каждой s3-ноды добавляются генератором (первая — primary, остальные backup):
    # server __NODE_NAME__ __NODE_IP__:__S3_PORT__ check inter 5s fall 3 rise 2 [backup]
__BCM_S3_NODES_BACKENDS__
